{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["@wdio/globals/types", "@types/mocha"]
  },
  "include": ["test/**/*.ts", "helpers/**/*.ts", "wdio.conf.ts"]
}
